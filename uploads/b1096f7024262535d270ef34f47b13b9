class student:
    def input_std_info(self):
        self.name = input('Enter name of the student : ')
        self.roll_number = input('Enter Roll no. of the student : ')
        self.email_address = input('Enter email_address of the student : ')

    def courses(self):
        self.no_of_courses = int(input('Enter no. of courses : '))
        self.courses_credit_hrs_dict = {}
        for i in range(self.no_of_courses):
            course_name = input('Enter name of the course : ')
            credit_hr_of_course = int(input('Enter credit hour of the course : '))
            self.courses_credit_hrs_dict[course_name] = credit_hr_of_course


    def calculate_gpa(self):
        self.courses_gpa_dict = {}
        self.sum_of_credit_hrs = 0
        for j in self.courses_credit_hrs_dict:
            self.sum_of_credit_hrs += self.courses_credit_hrs_dict[j]
            course_marks = int(input(f'Enter marks of {j} : '))
            if 85 <= course_marks <= 100:
                self.courses_gpa_dict[j] = 4.0

            if 80 <= course_marks <= 84:
                self.courses_gpa_dict[j] = 3.7

            if 75 <= course_marks <= 79:
                self.courses_gpa_dict[j] = 3.4

            if 70 <= course_marks <= 74:
                self.courses_gpa_dict[j] = 3.0

        print('The GPA of the courses are as follows : ')
        for k in self.courses_gpa_dict:
            print(f'GPA of {k} is',self.courses_gpa_dict[k])

    def calculate_cgpa(self):
        numerator_terms = []
        for l in self.courses_gpa_dict:
            prod = self.courses_gpa_dict[l] * self.courses_credit_hrs_dict[l]
            numerator_terms.append(prod)

        numerator = sum(numerator_terms)
        CGPA = numerator/self.sum_of_credit_hrs
        print(f'The CGPA of {self.name} is',CGPA)


    @classmethod
    def pass_check(cls):
        passed = input('If student is passed press P : ')
        if passed.upper() == 'P':
            print('Congratulations!!!')
        else:
            print('You have to concentrate on your studies. Best of Luck.')

    @staticmethod
    def no_of_student(Batch):
        if Batch == 'First Year':
            no_of_students = 50
        elif Batch == 'Second Year':
            no_of_students = 75
        elif Batch == 'Third Year':
            no_of_students = 110
        elif Batch == 'Fourth Year':
            no_of_students = 120
        return no_of_students

w = student()
w.input_std_info()
w.courses()
w.calculate_gpa()
w.calculate_cgpa()
w.pass_check()
print(w.no_of_student("First year"))

